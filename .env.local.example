# GrowthBook SDK connection (client key from SDK Connections).
# Leave blank to run in no-network mode where every flag returns its default.
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=
NEXT_PUBLIC_GROWTHBOOK_API_HOST=https://cdn.growthbook.io

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
# Leave blank to disable analytics in local dev.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
